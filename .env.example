# Supabase: только anon key (Settings → API → anon public). service_role — только в боте!
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="your_anon_public_key"

# URL сайта (для реф-ссылок в боте)
VITE_APP_URL="https://your-site.com"

# Опционально: Gemini для чата
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
